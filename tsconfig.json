{
    "compilerOptions": {
        "jsx": "react-jsx",
        "module": "Preserve",
        "target": "ES2020",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "strict": false,
        "skipLibCheck": true,
        "types": ["node", "react", "react-dom"]
    },
    "include": ["app", "src"]
}